# =============================================================================
# BirdNet-Behavior — Docker environment variables
#
# Copy this file to .env and edit the values for your setup:
#   cp .env.example .env
#
# Then start with:
#   docker compose up -d                                    # file-watch / RTSP
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.alsa.yml up -d        # USB/ALSA microphone
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.pulse.yml up -d       # PulseAudio / PipeWire
# =============================================================================

# -----------------------------------------------------------------------------
# Station location — required for solar schedule, BirdWeather, metadata filter
# -----------------------------------------------------------------------------
BIRDNET_LATITUDE=
BIRDNET_LONGITUDE=

# -----------------------------------------------------------------------------
# Audio input — choose ONE of the following methods:
#
#   Method 1 — ALSA microphone (USB mic on Raspberry Pi / Linux)
#     Requires docker-compose.alsa.yml overlay (passes /dev/snd into container)
#     Find your device: arecord -l  →  "card 1: Device [USB Audio], device 0:"
#     Format: plughw:<card>,<device>
# -----------------------------------------------------------------------------
BIRDNET_ALSA_DEVICE=

# -----------------------------------------------------------------------------
#   Method 2 — PulseAudio / PipeWire source
#     Requires docker-compose.pulse.yml overlay (mounts the PA socket)
#     Use "default" for the system default source, or a source name from:
#       pactl list short sources
# -----------------------------------------------------------------------------
BIRDNET_PIPEWIRE_DEVICE=

# -----------------------------------------------------------------------------
#   Method 3 — RTSP stream (IP camera, network audio source)
#     No overlay needed — works with the base docker-compose.yml
#     Single stream:
# -----------------------------------------------------------------------------
BIRDNET_RTSP_URL=

# Multi-stream (comma-separated, overrides BIRDNET_RTSP_URL):
BIRDNET_RTSP_URLS=

# -----------------------------------------------------------------------------
# Recording settings
# -----------------------------------------------------------------------------
# Duration of each audio segment in seconds (default: 15)
BIRDNET_SEGMENT_DURATION=15

# Recording schedule: "all-day" | "solar" | "fixed:HH:MM-HH:MM"
BIRDNET_RECORDING_SCHEDULE=all-day

# Suppress recording during night hours (requires lat/lon above)
BIRDNET_NIGHT_INHIBIT=

# Minutes offset from sunrise/sunset for twilight recording (default: 30)
BIRDNET_TWILIGHT_OFFSET=30

# -----------------------------------------------------------------------------
# Detection / inference
# -----------------------------------------------------------------------------
# Minimum confidence threshold for ML detections (0.0–1.0, default: varies by integration)
# Analysis window overlap in seconds (0.0–2.9, default: 0.0)
BIRDNET_OVERLAP=0.0

# Species frequency filter (metadata model threshold, default: 0.03)
BIRDNET_SF_THRESH=0.03

# Privacy filter: suppress chunks containing human voice (0.0 = disabled, try 0.02)
BIRDNET_PRIVACY_THRESHOLD=0.0

# Enable audio quality pre-filtering (SNR, spectral flatness, rain/wind rejection)
BIRDNET_QUALITY_FILTER=

# Minimum SNR in dB for quality filter (default: 3.0)
BIRDNET_QUALITY_MIN_SNR=3.0

# Language code for species name translation (default: en)
# Supported: de, fr, es, pt, it, ja, zh, ... (requires BirdNET label files)
BIRDNET_LANG=en

# -----------------------------------------------------------------------------
# Model — auto-downloaded from Zenodo on first run; override only if needed
# -----------------------------------------------------------------------------
# Skip the auto-download (bring your own model, mount it into /data/model)
BIRDNET_SKIP_MODEL_DOWNLOAD=

# Override paths (defaults to /data/model/<filename>)
BIRDNET_MODEL=
BIRDNET_LABELS=

# Optional: path to BirdNET metadata ONNX model for location-based filtering
BIRDNET_METADATA_MODEL=

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
# Listen address — inside the container this should be 0.0.0.0:8502
# (the entrypoint sets this automatically; only override if you need a
# different port number, e.g. 0.0.0.0:8080)
BIRDNET_LISTEN=0.0.0.0:8502

# Custom site name displayed in the web UI header
BIRDNET_SITENAME=

# Species info links: "ebird" | "allaboutbirds" | "none"
BIRDNET_INFO_SITE=ebird

# -----------------------------------------------------------------------------
# Storage / retention
# -----------------------------------------------------------------------------
# Audio format for extracted detection clips: wav | mp3 | flac | ogg
# Non-WAV formats require ffmpeg or sox installed in the container
BIRDNET_AUDIO_FORMAT=wav

# Maximum recordings kept per species (0 = unlimited)
BIRDNET_MAX_FILES_PER_SPECIES=0

# Frequency shift for saved clips in Hz (0 = disabled; try 1000–4000 for accessibility)
BIRDNET_FREQ_SHIFT_HZ=0

# -----------------------------------------------------------------------------
# Notifications — Apprise
# -----------------------------------------------------------------------------
BIRDNET_APPRISE_URL=
BIRDNET_APPRISE_CONFIG=

# Minimum confidence for notifications (default: 0.8)
BIRDNET_NOTIFY_CONFIDENCE=0.8

# Notification trigger: "each" | "new-species" | "new-species-daily"
BIRDNET_NOTIFY_TRIGGER=each

# Filter which species trigger notifications (comma-separated scientific names)
BIRDNET_NOTIFY_SPECIES_EXCLUDE=
BIRDNET_NOTIFY_SPECIES_ONLY=

# Custom notification templates (supports $comname, $sciname, $confidence, etc.)
BIRDNET_NOTIFY_TITLE_TEMPLATE=
BIRDNET_NOTIFY_BODY_TEMPLATE=

# Weekly report day: monday | tuesday | ... | sunday | disabled
BIRDNET_WEEKLY_REPORT_SCHEDULE=monday

# -----------------------------------------------------------------------------
# BirdWeather
# -----------------------------------------------------------------------------
BIRDNET_BIRDWEATHER_TOKEN=

# -----------------------------------------------------------------------------
# MQTT (Home Assistant, Node-RED, etc.)
# -----------------------------------------------------------------------------
BIRDNET_MQTT_HOST=
BIRDNET_MQTT_PORT=1883
BIRDNET_MQTT_CLIENT_ID=birdnet-behavior
BIRDNET_MQTT_USERNAME=
BIRDNET_MQTT_PASSWORD=
BIRDNET_MQTT_TOPIC_PREFIX=birdnet
BIRDNET_MQTT_RETAIN=
BIRDNET_MQTT_HA_DISCOVERY=

# -----------------------------------------------------------------------------
# Heartbeat (uptime monitoring)
# -----------------------------------------------------------------------------
BIRDNET_HEARTBEAT_URL=
