# =============================================================================
# BirdNet-Behavior — Docker environment variables
#
#   cp .env.example .env
#   # edit at minimum BIRDNET_LATITUDE, BIRDNET_LONGITUDE, and one audio source
#   docker compose up -d                                     # RTSP / file-watch
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.alsa.yml  up -d         # USB/ALSA mic
#   docker compose -f docker-compose.yml \
#                  -f docker-compose.pulse.yml up -d         # PulseAudio/PipeWire
#
# Every variable below maps 1:1 to a `--flag` on the `birdnet-behavior` binary
# (run `birdnet-behavior --help` for the full list). Blank / unset values keep
# the binary default. The detection / web UI settings that have NO env var —
# detection confidence threshold, per-species thresholds, sensitivity, email,
# rare-bird quarantine rules — are configured through the web UI at
# http://localhost:8502/admin/settings once the container is running.
# =============================================================================


# -----------------------------------------------------------------------------
# Station location — required for solar schedule, species filter, BirdWeather
# -----------------------------------------------------------------------------
BIRDNET_LATITUDE=
BIRDNET_LONGITUDE=


# -----------------------------------------------------------------------------
# Audio input — set ONE of the following. The Docker entrypoint prints a
# warning at startup if none is set; the web UI still comes up but no
# detections will be produced until an audio source is configured.
# -----------------------------------------------------------------------------

# Method 1 — ALSA microphone (USB mic on Raspberry Pi / Linux)
#   Requires the docker-compose.alsa.yml overlay (passes /dev/snd in).
#   Find the device on the host:  arecord -l
#     → "card 1: Device [USB Audio], device 0:"  →  plughw:1,0
BIRDNET_ALSA_DEVICE=

# Method 2 — PulseAudio / PipeWire source
#   Requires the docker-compose.pulse.yml overlay (mounts the PA socket).
#   Use "default" for the system default source, or a source name from:
#     pactl list short sources
BIRDNET_PIPEWIRE_DEVICE=

# Method 3 — RTSP stream (IP camera, network audio source)
#   Works with the base docker-compose.yml — no overlay needed.
BIRDNET_RTSP_URL=

# Multiple RTSP streams (comma-separated, overrides BIRDNET_RTSP_URL).
# Each stream gets its own capture pipeline; files are prefixed RTSP_1-, RTSP_2-…
BIRDNET_RTSP_URLS=

# Method 4 — File-watch mode
#   No env var needed: drop WAV files into the `birdnet-data` volume at
#   /data/recordings (the default BIRDNET_WATCH_DIR) and they'll be processed
#   as they appear.


# -----------------------------------------------------------------------------
# Recording schedule
# -----------------------------------------------------------------------------
# Duration of each captured segment in seconds
BIRDNET_SEGMENT_DURATION=15

# Recording schedule: "all-day" | "solar" | "fixed:HH:MM-HH:MM"
BIRDNET_RECORDING_SCHEDULE=all-day

# Inhibit recording during night hours (requires BIRDNET_LATITUDE/LONGITUDE).
# Set to any non-empty value to enable (e.g. "1").
BIRDNET_NIGHT_INHIBIT=

# Minutes offset from sunrise/sunset for twilight recording
BIRDNET_TWILIGHT_OFFSET=30


# -----------------------------------------------------------------------------
# Detection / inference
#
# NOTE: The detection confidence threshold and sensitivity are NOT exposed as
# environment variables. Configure them via /admin/settings in the web UI
# (they are persisted in the SQLite settings table).
# -----------------------------------------------------------------------------

# Analysis window overlap in seconds (0.0–2.9). Higher = more sensitivity,
# more CPU. Default 0.0 (no overlap).
BIRDNET_OVERLAP=0.0

# Species frequency filter — metadata model threshold (0.0–1.0).
# Filters out species unlikely at this lat/lon and time of year.
BIRDNET_SF_THRESH=0.03

# Privacy filter: suppress chunks containing human voice (0.0 = disabled).
# Typical values when enabled: 0.01–0.03.
BIRDNET_PRIVACY_THRESHOLD=0.0

# Enable audio quality pre-filtering (SNR, spectral flatness, rain/wind).
# Set to any non-empty value to enable.
BIRDNET_QUALITY_FILTER=

# Minimum SNR in dB for the quality filter (used only when the filter is on)
BIRDNET_QUALITY_MIN_SNR=3.0

# Species name translation language: en | de | fr | es | pt | it | ja | zh | …
# Non-English languages require BirdNET label files in BIRDNET_LABELS_DIR.
BIRDNET_LANG=en

# Directory containing BirdNET language label files (labels_de.txt, etc.)
BIRDNET_LABELS_DIR=


# -----------------------------------------------------------------------------
# Model
#
# The BirdNET+ V3.0 model (~541 MB) is downloaded automatically from Zenodo
# into /data/model on first run. Override only if you want to bring your own.
# -----------------------------------------------------------------------------

# Skip the Zenodo download (bring your own model & labels at the paths below).
# Set to "1" to skip.
BIRDNET_SKIP_MODEL_DOWNLOAD=

# Explicit model paths inside the container (default: /data/model/<filename>)
BIRDNET_MODEL=
BIRDNET_LABELS=

# Directory used by the entrypoint when auto-downloading (default: /data/model)
BIRDNET_MODEL_DIR=

# Optional: BirdNET metadata ONNX model for location-based species filtering
BIRDNET_METADATA_MODEL=


# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
# Listen address *inside* the container. Must bind 0.0.0.0 for Docker to
# publish it; the entrypoint enforces this automatically. Change only the
# port number here if you want a non-8502 listen port inside the container.
BIRDNET_LISTEN=0.0.0.0:8502

# Host port the web UI is published on. The compose file maps this to 8502
# inside the container, so you can use e.g. BIRDNET_PORT=8080 to serve at
# http://localhost:8080 without changing the container-internal port.
BIRDNET_PORT=8502

# Custom site name shown in the web UI header
BIRDNET_SITENAME=

# Species info links: "ebird" | "allaboutbirds" | "none"
BIRDNET_INFO_SITE=ebird


# -----------------------------------------------------------------------------
# Storage / retention
# -----------------------------------------------------------------------------
# Audio format for extracted detection clips: wav | mp3 | flac | ogg
# Non-WAV formats require ffmpeg or sox in the container image.
BIRDNET_AUDIO_FORMAT=wav

# Maximum extracted recordings kept per species (0 = unlimited)
BIRDNET_MAX_FILES_PER_SPECIES=0

# Frequency shift applied to saved clips in Hz (0 = disabled).
# Try 1000–4000 Hz to make high-frequency calls accessible.
BIRDNET_FREQ_SHIFT_HZ=0

# Comma-separated paths never auto-purged by the disk manager
BIRDNET_DISK_EXCLUDE=

# Watch directory inside the container (WAV files dropped here are processed).
# Defaults to /data/recordings — change only if you remap the data volume.
BIRDNET_WATCH_DIR=

# Directory with custom species images (overrides Wikipedia cache).
# Files named {lowercase_sci_name_with_underscores}.jpg, e.g. turdus_merula.jpg.
BIRDNET_CUSTOM_IMAGE_DIR=

# Cached Wikipedia species images (default: /data/cache)
BIRDNET_IMAGE_CACHE_DIR=

# DuckDB behavioral analytics DB file — enables the /analytics page.
# Requires the `:latest-analytics` image (or BUILD_FEATURES=analytics).
# Default inside the container: /data/analytics.db
BIRDNET_ANALYTICS_DB=


# -----------------------------------------------------------------------------
# Notifications — Apprise
# -----------------------------------------------------------------------------
BIRDNET_APPRISE_URL=
BIRDNET_APPRISE_CONFIG=

# Minimum confidence to trigger a notification (0.0–1.0)
BIRDNET_NOTIFY_CONFIDENCE=0.8

# Notification trigger: "each" | "new-species" | "new-species-daily"
BIRDNET_NOTIFY_TRIGGER=each

# Filter which species trigger notifications (comma-separated scientific names)
BIRDNET_NOTIFY_SPECIES_EXCLUDE=
BIRDNET_NOTIFY_SPECIES_ONLY=

# Custom notification templates
# (supports $comname, $sciname, $confidence, $time, $date, …)
BIRDNET_NOTIFY_TITLE_TEMPLATE=
BIRDNET_NOTIFY_BODY_TEMPLATE=

# Weekly report day: monday | tuesday | … | sunday | disabled
BIRDNET_WEEKLY_REPORT_SCHEDULE=monday


# -----------------------------------------------------------------------------
# BirdWeather
# -----------------------------------------------------------------------------
BIRDNET_BIRDWEATHER_TOKEN=


# -----------------------------------------------------------------------------
# MQTT (Home Assistant, Node-RED, Mosquitto, …)
# -----------------------------------------------------------------------------
BIRDNET_MQTT_HOST=
BIRDNET_MQTT_PORT=1883
BIRDNET_MQTT_CLIENT_ID=birdnet-behavior
BIRDNET_MQTT_USERNAME=
BIRDNET_MQTT_PASSWORD=
BIRDNET_MQTT_TOPIC_PREFIX=birdnet
# Set to any non-empty value to enable
BIRDNET_MQTT_RETAIN=
BIRDNET_MQTT_HA_DISCOVERY=


# -----------------------------------------------------------------------------
# Heartbeat (uptime monitoring ping URL)
# -----------------------------------------------------------------------------
BIRDNET_HEARTBEAT_URL=


# -----------------------------------------------------------------------------
# Docker-only knobs (read by docker-compose, not the binary)
# -----------------------------------------------------------------------------

# Build the image locally with analytics support (DuckDB).
# Adds ~7 min to the first `docker compose build` for the C++ compile.
#   BUILD_FEATURES=analytics docker compose build
BUILD_FEATURES=

# Host UID whose PulseAudio/PipeWire socket is mounted by the pulse overlay
# (default 1000). Override if your user's UID is different.
#   id -u
PULSE_UID=1000
