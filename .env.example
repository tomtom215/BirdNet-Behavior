# =============================================================================
# BirdNet-Behavior — Docker environment variables
#
# QUICK START
#   1. cp .env.example .env
#   2. Fill in the REQUIRED section below (lat/lon + one audio source).
#   3. docker compose up -d       ← base compose, works for RTSP/file-watch
#      …or an overlay for live mic capture:
#        docker compose -f docker-compose.yml -f docker-compose.alsa.yml  up -d
#        docker compose -f docker-compose.yml -f docker-compose.pulse.yml up -d
#   4. Open http://localhost:8502
#
# The BirdNET+ V3.0 model (~541 MB) is downloaded automatically from Zenodo on
# first run — you do not need to pick or fetch a model yourself.
#
# Settings with no env var (detection confidence threshold, sensitivity,
# per-species thresholds, email, rare-bird quarantine) live in the web UI at
# http://localhost:8502/admin/settings.
# =============================================================================


# =============================================================================
#   REQUIRED — edit these three things before first run
# =============================================================================

# --- 1. Station location -----------------------------------------------------
#   Used for the solar recording schedule, species frequency filter,
#   BirdWeather uploads, and the dashboard sunrise/sunset markers.
BIRDNET_LATITUDE=
BIRDNET_LONGITUDE=

# --- 2. Audio source — set exactly ONE of the following ---------------------

# Option A — USB / ALSA microphone (most Raspberry Pi users)
#   Find the device:  arecord -l
#     → "card 1: Device [USB Audio], device 0:"   →   plughw:1,0
#   Start with:
#     docker compose -f docker-compose.yml -f docker-compose.alsa.yml up -d
BIRDNET_ALSA_DEVICE=

# Option B — RTSP stream (IP camera / network audio)
#   Works with the base docker-compose.yml — no overlay needed.
#     docker compose up -d
BIRDNET_RTSP_URL=

# Option C — PulseAudio / PipeWire source (desktop Linux)
#   Use "default" for the system default source, or a name from:
#     pactl list short sources
#   Start with:
#     docker compose -f docker-compose.yml -f docker-compose.pulse.yml up -d
BIRDNET_PIPEWIRE_DEVICE=

# --- 3. Which image to pull --------------------------------------------------
#   latest            — standard build (SQLite only)
#   latest-analytics  — adds DuckDB behavioral analytics (activity sessions,
#                       resident-vs-migrant, dawn chorus validation, etc.)
BIRDNET_IMAGE_TAG=latest


# =============================================================================
#   OPTIONAL — safe defaults, edit only if you want to change behaviour.
#   You can leave this entire section untouched and the container will work.
# =============================================================================

# --- Web server --------------------------------------------------------------
# Host port for the web UI (container always listens on 8502 internally).
BIRDNET_PORT=8502
# Custom site name shown in the web UI header.
BIRDNET_SITENAME=
# Species info link target: ebird | allaboutbirds | none
BIRDNET_INFO_SITE=ebird

# --- Multi-stream RTSP (overrides BIRDNET_RTSP_URL) --------------------------
#   Comma-separated; each URL gets its own capture pipeline.
BIRDNET_RTSP_URLS=

# --- Recording schedule ------------------------------------------------------
# Seconds per captured segment.
BIRDNET_SEGMENT_DURATION=15
# Schedule mode: all-day | solar | fixed:HH:MM-HH:MM
BIRDNET_RECORDING_SCHEDULE=all-day
# Non-empty value = suppress recording during night hours (needs lat/lon).
BIRDNET_NIGHT_INHIBIT=
# Minutes offset from sunrise/sunset for twilight recording.
BIRDNET_TWILIGHT_OFFSET=30

# --- Detection / inference ---------------------------------------------------
# Note: confidence threshold and sensitivity are configured in /admin/settings.
# Analysis window overlap, 0.0–2.9 seconds (higher = more sensitive, more CPU).
BIRDNET_OVERLAP=0.0
# Species frequency filter (metadata model occurrence threshold).
BIRDNET_SF_THRESH=0.03
# Human-voice privacy filter (0.0 = off, try 0.02 to enable).
BIRDNET_PRIVACY_THRESHOLD=0.0
# Non-empty = enable SNR / spectral flatness / rain-wind rejection.
BIRDNET_QUALITY_FILTER=
BIRDNET_QUALITY_MIN_SNR=3.0
# Species name translation language: en | de | fr | es | pt | it | ja | zh | …
BIRDNET_LANG=en

# --- Notifications (Apprise) -------------------------------------------------
BIRDNET_APPRISE_URL=
BIRDNET_APPRISE_CONFIG=
BIRDNET_NOTIFY_CONFIDENCE=0.8
# Trigger mode: each | new-species | new-species-daily
BIRDNET_NOTIFY_TRIGGER=each
BIRDNET_NOTIFY_SPECIES_EXCLUDE=
BIRDNET_NOTIFY_SPECIES_ONLY=
BIRDNET_NOTIFY_TITLE_TEMPLATE=
BIRDNET_NOTIFY_BODY_TEMPLATE=
# Weekly report day: monday | tuesday | … | sunday | disabled
BIRDNET_WEEKLY_REPORT_SCHEDULE=monday

# --- BirdWeather -------------------------------------------------------------
BIRDNET_BIRDWEATHER_TOKEN=

# --- MQTT (Home Assistant, Node-RED, Mosquitto, …) ---------------------------
BIRDNET_MQTT_HOST=
BIRDNET_MQTT_PORT=1883
BIRDNET_MQTT_CLIENT_ID=birdnet-behavior
BIRDNET_MQTT_USERNAME=
BIRDNET_MQTT_PASSWORD=
BIRDNET_MQTT_TOPIC_PREFIX=birdnet
BIRDNET_MQTT_RETAIN=
BIRDNET_MQTT_HA_DISCOVERY=

# --- Heartbeat (uptime monitoring ping URL) ----------------------------------
BIRDNET_HEARTBEAT_URL=

# --- Storage / retention -----------------------------------------------------
# wav | mp3 | flac | ogg (non-WAV needs ffmpeg or sox in the image)
BIRDNET_AUDIO_FORMAT=wav
# Maximum extracted recordings kept per species (0 = unlimited).
BIRDNET_MAX_FILES_PER_SPECIES=0
# Frequency shift applied to saved clips in Hz (0 = disabled, try 1000–4000).
BIRDNET_FREQ_SHIFT_HZ=0
# Comma-separated paths the disk manager must never auto-purge.
BIRDNET_DISK_EXCLUDE=
# Directory with custom species images (overrides Wikipedia cache).
BIRDNET_CUSTOM_IMAGE_DIR=


# =============================================================================
#   ADVANCED — internal container paths, custom models, local builds.
#   Most users should leave this entire section blank.
# =============================================================================

# Container paths (correct by default; change only if you remap the volume).
BIRDNET_LISTEN=0.0.0.0:8502
BIRDNET_WATCH_DIR=/data/recordings
BIRDNET_IMAGE_CACHE_DIR=/data/cache
BIRDNET_ANALYTICS_DB=/data/analytics.db
BIRDNET_MODEL_DIR=/data/model

# Bring-your-own model (leave blank — the entrypoint auto-downloads BirdNET+
# V3.0 from Zenodo on first run; set these ONLY if you have a custom model).
BIRDNET_SKIP_MODEL_DOWNLOAD=
BIRDNET_MODEL=
BIRDNET_LABELS=
BIRDNET_METADATA_MODEL=
BIRDNET_LABELS_DIR=

# Host UID whose PulseAudio/PipeWire socket the pulse overlay mounts
# (run `id -u` on the host if your UID is not 1000).
PULSE_UID=1000

# Local builds only — pass `BUILD_FEATURES=analytics` to `docker compose build`
# to compile the analytics variant yourself instead of pulling it from GHCR.
BUILD_FEATURES=
